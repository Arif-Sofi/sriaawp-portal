# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is git-ignored.

# Supabase — public client (browser-safe). Used by @supabase/supabase-js.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Supabase — service role (server-only). Bypasses RLS; never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Auth.js v5 — generate with: npx auth secret
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="generate-via-npx-auth-secret"

# Auth.js v5 — base URL for callbacks. Override per environment.
AUTH_URL="http://localhost:3000"

# Resend (magic-link delivery). Sign up at https://resend.com,
# add and verify the SRIAAWP domain, then create an API key.
# Leave blank in development — auth.ts falls back to console.log of the magic link.
AUTH_RESEND_KEY=""
AUTH_EMAIL_FROM="SRIAAWP <no-reply@sriaawp.edu.my>"

# Gemini API key (Vercel AI SDK + @ai-sdk/google).
# Used by both embedding pipeline (ADR-006) and chat LLM (ADR-007).
# Free tier for FYP1/FYP2 dev with synthetic data; paid tier required for production
# with real student data per ADR-008 (PDPA: opt out of model training).
GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key"

# Postgres connection string used by the application at runtime (Drizzle +
# @auth/drizzle-adapter). On Supabase, point this at the Transaction Pooler
# (port 6543) so serverless connections reuse a pool. Local Supabase default
# below targets the direct port — fine for development.
DATABASE_URL="postgres://postgres:postgres@127.0.0.1:54322/postgres"

# Direct (non-pooled) connection string used by drizzle-kit migrations and
# the seed script. On hosted Supabase this is port 5432; locally it is the
# same as DATABASE_URL.
DATABASE_URL_DIRECT=""

# 32-byte symmetric key used by pgcrypto's pgp_sym_encrypt to column-encrypt
# student IC numbers (ADR-008 PDPA). Rotate with re-encryption job; never log.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
IC_ENCRYPTION_KEY="replace-me-with-a-32-byte-base64-string"
